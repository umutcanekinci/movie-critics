-- Movies
INSERT INTO movie (title, release_year, language, country_of_origin, genre, director_id, is_watched, leading_actor_id, supporting_actor_id, about, rating, comments, poster, parental_restriction) VALUES
('Inception',         2010, 'English', 'USA', 'Sci-Fi',   '1', 1, '6', NULL, 'A skilled thief is offered a chance to have his criminal record erased if he can successfully perform inception: planting an idea into a target''s subconscious through dream-sharing technology.', 9, 'Mind-bending and visually stunning.',  NULL, 0),
('Interstellar',      2014, 'English', 'USA', 'Sci-Fi',   '1', 1, '8', NULL, 'A team of astronauts travels through a wormhole near Saturn in search of a new home for humanity as Earth becomes uninhabitable.',                                                             9, 'Emotional, ambitious, and scientifically rich.', NULL, 0),
('The Dark Knight',   2008, 'English', 'USA', 'Action',   '1', 1, NULL,'NULL','When the anarchic Joker plunges Gotham into chaos, Batman must confront the limits of his own moral code to stop him.',                                                                         10,'The greatest superhero film ever made.',         NULL, 0),
('Oppenheimer',       2023, 'English', 'USA', 'Drama',    '1', 0, '8', NULL, 'The story of J. Robert Oppenheimer and his role in the development of the atomic bomb during World War II.',                                                                                         9, 'A stunning three-hour biographical epic.',       NULL, 0),
('Schindler''s List', 1993, 'English', 'USA', 'Drama',    '2', 1, NULL, NULL,'Industrialist Oskar Schindler saves over a thousand Jewish lives during the Holocaust by employing them in his factories.',                                                                          10,'A masterpiece. Devastating and important.',      NULL, 0),
('Pulp Fiction',      1994, 'English', 'USA', 'Crime',    '3', 1, '9', NULL, 'The lives of two mob hitmen, a boxer, a gangster and his wife intertwine in four tales of violence, humour, and redemption.',                                                                         9, 'Iconic dialogues and non-linear storytelling.',  NULL, 1),
('Inglourious Basterds',2009,'English','USA', 'War',      '3', 0, NULL, NULL,'During the Nazi occupation of France, a group of Jewish-American soldiers plan to assassinate the Nazi leadership at a cinema.',                                                                      8, 'Bold, witty, and wildly entertaining.',          NULL, 1),
('Gladiator',         2000, 'English', 'USA', 'Action',   '4', 1, NULL, NULL,'Betrayed by the corrupt emperor who murdered his family, Roman general Maximus rises from slavery to seek vengeance in the Colosseum.',                                                              8, 'Epic, brutal, and emotionally powerful.',         NULL, 1),
('Titanic',           1997, 'English', 'USA', 'Romance',  '5', 1, '6', NULL, 'A young aristocrat falls in love with a kind-hearted drifter aboard the doomed ocean liner on its ill-fated maiden voyage.',                                                                         8, 'A timeless love story wrapped in spectacle.',    NULL, 0),
('Forrest Gump',      1994, 'English', 'USA', 'Drama',    NULL,1, '7', NULL, 'Decades of American history unfold through the eyes of a good-natured man from Alabama with an extraordinary life and an IQ of 75.',                                                                 9, 'Heartwarming, funny, and unforgettable.',         NULL, 0);

